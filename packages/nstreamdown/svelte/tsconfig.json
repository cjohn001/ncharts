{
  "extends": "../../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "../../../dist/packages/nstreamdown/svelte",
    "rootDir": ".",
    "declaration": true,
    "declarationDir": "../../../dist/packages/nstreamdown/svelte",
    "baseUrl": ".",
    "module": "ESNext",
    "moduleResolution": "node",
    "target": "ESNext",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": false,
    "skipLibCheck": true,
    "paths": {
      "@nstudio/nstreamdown": ["../index.d.ts"]
    }
  },
  "include": ["**/*.ts"],
  "exclude": ["**/*.spec.ts", "**/*.test.ts", "node_modules"]
}
