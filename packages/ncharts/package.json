{
  "name": "@nstudio/ncharts",
  "version": "1.0.2",
  "description": "Native iOS/Android charting for NativeScript using DGCharts (iOS) and MPAndroidChart (Android)",
  "main": "index",
  "types": "index.d.ts",
  "nativescript": {
    "platforms": {
      "ios": "8.0.0",
      "android": "8.0.0"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/nstudio/ncharts.git"
  },
  "keywords": [
    "NativeScript",
    "JavaScript",
    "TypeScript",
    "iOS",
    "Android",
    "charts",
    "graphs",
    "data visualization",
    "line chart",
    "bar chart",
    "pie chart",
    "DGCharts",
    "MPAndroidChart"
  ],
  "author": {
    "name": "nStudio",
    "email": "oss@nstudio.io"
  },
  "bugs": {
    "url": "https://github.com/nstudio/ncharts/issues"
  },
  "license": "Apache-2.0",
  "homepage": "https://github.com/nstudio/ncharts",
  "readmeFilename": "README.md",
  "bootstrapper": "@nativescript/plugin-seed",
  "peerDependencies": {
    "@nativescript/core": ">=8.0.0",
    "@nativescript/angular": ">=18.0.0",
    "@angular/core": ">=18.0.0",
    "vue": ">=3.0.0",
    "nativescript-vue": ">=3.0.0",
    "react": ">=18.0.0",
    "react-nativescript": ">=5.0.0",
    "solid-js": ">=1.0.0",
    "dominative": ">=0.1.0",
    "svelte": ">=4.0.0",
    "@nativescript-community/svelte-native": ">=1.0.0"
  },
  "peerDependenciesMeta": {
    "@nativescript/angular": {
      "optional": true
    },
    "@angular/core": {
      "optional": true
    },
    "vue": {
      "optional": true
    },
    "nativescript-vue": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "react-nativescript": {
      "optional": true
    },
    "solid-js": {
      "optional": true
    },
    "dominative": {
      "optional": true
    },
    "svelte": {
      "optional": true
    },
    "@nativescript-community/svelte-native": {
      "optional": true
    }
  },
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "default": "./index.ios.js"
    },
    "./angular": {
      "types": "./angular/index.d.ts",
      "default": "./angular/fesm2022/nstudio-ncharts-angular.mjs"
    },
    "./react": {
      "types": "./react/index.d.ts",
      "default": "./react/index.js"
    },
    "./solid": {
      "types": "./solid/index.d.ts",
      "default": "./solid/index.js"
    },
    "./svelte": {
      "types": "./svelte/index.d.ts",
      "default": "./svelte/index.js"
    },
    "./vue": {
      "types": "./vue/index.d.ts",
      "default": "./vue/index.js"
    }
  }
}
